generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums removed as SQLite doesn't support them natively; fields already use Strings.

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  role          String    @default("BAND") // "BAND" or "VENUE"
  name          String?
  zip           String?
  bio           String?
  socialLinks   String?   
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bandProfile   BandProfile?
  venueProfile  VenueProfile?
  
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  
  bookingCampaigns  BookingCampaign[]
}

model BandProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  slug            String?  @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  genre           String?
  yearsPerforming Int?
  members         String?  
  coverOrOriginal String?  // "COVER", "ORIGINAL", "DJ", "KARAOKE"
  bandType        String?  // Detailed type
  
  // Geospatial
  latitude        Float?
  longitude       Float?
  location        String?  // City, State
  
  // Activity
  activeStatus    Boolean  @default(true)
  lastGigDate     DateTime?
  
  headerImage     String?
  design1Image    String?
  design2Image    String?
  profileImage    String?
  backgroundImage String?
  bio             String?

  // Streaming URLs
  spotifyUrl      String?
  appleMusicUrl   String?
  tidalUrl        String?
  youtubeUrl      String?
  bandcampUrl     String?
  soundcloudUrl   String?

  // EPK Questionnaire Details
  isTouring       Boolean  @default(false)
  isNational      Boolean  @default(false)
  isSigned        Boolean  @default(false)
  hasRepresentation Boolean @default(false)
  representationDetails String?
  contactEmail    String?
  contactPhone    String?
  bandRider       String?  // Rider technical requirements (text)
  providesPA      Boolean  @default(false)
  hasSoundGuy     Boolean  @default(false)
  handlesPresales Boolean  @default(false)

  // ── Match & Book criteria ─────────────────────────────────────
  minimumGuarantee  Float?   // Artist's minimum pay floor
  expectedDraw      Int?     // Expected local draw
  primaryGenre      String?  // Strict genre match
  secondaryGenre    String?  // Soft genre match
  
  tracks          Track[]
  videos          Video[]
  storeItems      StoreItem[]
  events          Event[]

  swipes          Swipe[]
  matches         Match[]

  lastCrawledAt   DateTime?
}

model VenueProfile {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name            String   @unique
  slug            String?  @unique
  address         String?
  latitude        Float?
  longitude       Float?
  
  phone           String?
  bookingEmail    String?
  contactName     String?
  website         String?
  
  venueType       String?  // "BAR", "CLUB", "STADIUM", etc.
  ageRequirement  String? 
  averagePay      String?
  coverCost       String?
  
  openDates       String? // Summary of upcoming availability
  bookingHistory  String? // Kinds of bands they book
  
  interiorImage   String?
  exteriorImage   String?
  stageImage      String?
  genres          String?
  payType         String?
  rssFeedUrl      String?

  // Questionnaire details
  bookingDays            String?  // e.g., "Thursday, Friday, Saturday"
  eventFeedUrl           String?
  targetBandsDescription  String?
  targetBookingNights    String?

  // ── Match & Book criteria ─────────────────────────────────────
  capacity        Int?     // Room capacity / draw expectations
  defaultBudget   Float?   // Default budget per slot
  
  claimed         Boolean  @default(false)
  lastCrawledAt   DateTime?
  
  events          Event[]
  bookingAttempts BookingAttempt[]
  slots           Slot[]
  swipes          Swipe[]
  matches         Match[]
}

// ── Match & Book: Core Models ─────────────────────────────────────────────────

/// An open stage slot posted by a venue that bands can swipe on
model Slot {
  id              String   @id @default(cuid())
  venueId         String
  venue           VenueProfile @relation(fields: [venueId], references: [id], onDelete: Cascade)

  date            DateTime
  startTime       String?  // "9:00 PM"
  endTime         String?  // "12:00 AM"
  setLength       Int?     // minutes

  budget          Float?   // Per-slot budget ceiling
  targetDraw      Int?     // Minimum expected draw from the artist
  genres          String?  // Desired genres (comma-separated)
  notes           String?  // Stage notes, vibe, etc.

  // OPEN | PROVISIONAL | BOOKED | CANCELLED
  status          String   @default("OPEN")

  swipes          Swipe[]
  match           Match?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Records every swipe action (both band→slot and venue→band)
model Swipe {
  id              String   @id @default(cuid())

  /// "BAND" swiped on the slot, or "VENUE" swiped on the band
  initiator       String

  /// "RIGHT" = like/request, "LEFT" = pass
  direction       String

  bandId          String
  band            BandProfile @relation(fields: [bandId], references: [id], onDelete: Cascade)

  venueId         String
  venue           VenueProfile @relation(fields: [venueId], references: [id], onDelete: Cascade)

  slotId          String
  slot            Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  /// Each party can only swipe once per slot+band combination
  @@unique([initiator, bandId, slotId])
}

/// Created when both parties mutually swipe RIGHT — triggers provisional booking
model Match {
  id              String   @id @default(cuid())

  bandId          String
  band            BandProfile @relation(fields: [bandId], references: [id], onDelete: Cascade)

  venueId         String
  venue           VenueProfile @relation(fields: [venueId], references: [id], onDelete: Cascade)

  slotId          String   @unique
  slot            Slot     @relation(fields: [slotId], references: [id], onDelete: Cascade)

  // PROVISIONAL | CONFIRMED | CANCELLED
  status          String   @default("PROVISIONAL")

  /// JSON settlement sheet: agreed pay, date, set length, contacts
  draftContract   String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Existing Supporting Models ────────────────────────────────────────────────

model Track {
  id            String   @id @default(cuid())
  bandId        String
  band          BandProfile @relation(fields: [bandId], references: [id], onDelete: Cascade)
  title         String
  url           String
  albumArt      String?
  isDownloadable Boolean @default(false)
  price         Float?
  order         Int      @default(0)
}

model Video {
  id            String   @id @default(cuid())
  bandId        String
  band          BandProfile @relation(fields: [bandId], references: [id], onDelete: Cascade)
  title         String
  url           String   
}

model StoreItem {
  id            String   @id @default(cuid())
  bandId        String
  band          BandProfile @relation(fields: [bandId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  price         Float
  image         String?
}

model Event {
  id            String   @id @default(cuid())
  bandId        String?
  band          BandProfile? @relation(fields: [bandId], references: [id], onDelete: Cascade)
  venueId       String?
  venue         VenueProfile? @relation(fields: [venueId], references: [id], onDelete: Cascade)
  
  date          DateTime
  status        String @default("AVAILABLE") // "AVAILABLE" or "BOOKED"
  compensation  String? 
}

model Message {
  id            String   @id @default(cuid())
  senderId      String
  sender        User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId    String
  receiver      User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content       String
  createdAt     DateTime @default(now())
}

model MusicResource {
  id              String   @id @default(cuid())
  name            String   @unique
  type            String   // "STUDIO", "REHEARSAL", "SHOP"
  
  address         String?
  latitude        Float?
  longitude       Float?
  
  phone           String?
  email           String?
  website         String?
  
  // Specific metadata
  description     String?
  services        String?  // e.g., "Mixing, Mastering, Gear Rental"
  rates           String?  // e.g., "$50/hr"
  brands          String?  // For shops: "Fender, Gibson, etc."
  
  lastCrawledAt   DateTime?
}

model BookingCampaign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  targetDates     String   // Serialized dates array
  maxRadius       Int      // in miles
  minCompensation Float?
  
  status          String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  attempts        BookingAttempt[]
  
  createdAt       DateTime @default(now())
}

model BookingAttempt {
  id                String   @id @default(cuid())
  campaignId        String
  campaign          BookingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  venueId           String
  venue             VenueProfile @relation(fields: [venueId], references: [id], onDelete: Cascade)
  
  status            String   @default("PENDING") // PENDING, SENT, REPLIED, CONFIRMED, DECLINED
  resendId          String?  // The Resend Message ID from the initial outbound
  messageId         String?  // The Message-ID header for threading
  threadId          String?  // Internal thread identifier
  
  negotiationLog    String?  // AI's summary of the conversation
  lastActivityAt    DateTime @default(now())
}

model PilotLog {
  id          String   @id @default(cuid())
  campaignId  String?
  level       String   @default("INFO") // INFO, WARN, ERROR, AI
  message     String
  createdAt   DateTime @default(now())
}
